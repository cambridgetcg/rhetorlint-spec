{
  "name": "@rhetorlint/core",
  "version": "0.1.1",
  "description": "Reference engine for the RhetorLint spec: marks rhetorical tells in text, on-device, zero dependencies. Reads the language, never the person.",
  "type": "module",
  "license": "MIT",
  "main": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./sarif": {
      "types": "./sarif.d.ts",
      "default": "./sarif.mjs"
    },
    "./signals": {
      "types": "./signals.d.ts",
      "default": "./signals.mjs"
    }
  },
  "files": [
    "index.mjs",
    "index.d.ts",
    "sarif.mjs",
    "sarif.d.ts",
    "signals.mjs",
    "signals.d.ts",
    "README.md"
  ],
  "homepage": "https://github.com/cambridgetcg/rhetorlint-spec#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cambridgetcg/rhetorlint-spec.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rhetorlint",
    "rhetoric",
    "manipulation-detection",
    "media-literacy",
    "on-device"
  ],
  "sideEffects": false
}
