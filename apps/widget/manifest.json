{
  "manifest_version": 3,
  "name": "RhetorLint — read the subtext",
  "version": "0.1.0",
  "description": "Select text on any page and mark the rhetorical tells — hedges, absolutes, deleted subjects, spin. On-device; nothing leaves your browser.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "RhetorLint — mark the selection (Alt+Shift+R)"
  },
  "commands": {
    "rhetorlint-run": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Mark the current selection"
    }
  },
  "permissions": ["activeTab"]
}
